# Porta do servidor
PORT=3000

# Chave de autenticação da API (deixe vazio para dev sem auth)
API_KEY=

# Caminho para o arquivo de credenciais do Firebase Admin SDK
# Baixe em: Firebase Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada
# Renomeie o arquivo para serviceAccountKey.json e coloque na pasta api/
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
